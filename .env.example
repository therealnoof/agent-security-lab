# =============================================================
#  agent-security-lab — environment template
#  Copy to .env and fill in real values. Never commit .env.
# =============================================================

# --- F5 AI Security (CalypsoAI) ---
# Per-learner token from the lab tenant.
CALYPSOAI_TOKEN=

# OpenAI-compatible proxy base URL for the lab tenant.
#
# Format: https://www.<region>.calypsoai.app/openai/<PROVIDER-NAME>
#
# IMPORTANT: the path segment after /openai/ is the PROVIDER name (the
# upstream-LLM connection your tenant admin configured), NOT the project
# name and NOT the project's friendlyId. Find it in:
#   GET https://www.<region>.calypsoai.app/backend/v1/providers
# and use the `name` field, e.g. "gemini-2-5-flash".
#
# Example:
#   https://www.us1.calypsoai.app/openai/gemini-2-5-flash
CALYPSOAI_OPENAI_API_BASE=

# Model name the provider exposes. For Gemini-backed providers this is
# typically "gemini-2.5-flash"; for OpenAI providers, "gpt-4o-mini" etc.
# Check the provider's `inputs.model` field in the providers list above.
CALYPSOAI_MODEL=

# --- Keycloak (OAuth 2.1 IdP) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-locally
KEYCLOAK_REALM=agent-lab

# Override these to rotate the lab client secrets. Defaults match
# keycloak/realm/agent-lab-realm.json so the lab works out of the box.
# In a real environment NEVER ship secrets in source — these are only
# OK because Keycloak runs locally and the realm is throwaway.
MCP_OAUTH_CLIENT_ID=mcp-server
MCP_OAUTH_CLIENT_SECRET=mcp-server-secret-change-me
REMEDIATION_OAUTH_CLIENT_ID=agent-remediation
REMEDIATION_OAUTH_CLIENT_SECRET=agent-remediation-secret-change-me

# Set to 1 to disable OAuth on the MCP server entirely (Slice A
# behavior). Leave unset for Slice B.
MCP_SKIP_AUTH=

# --- Sandbox Postgres (the "tickets" DB the unhardened Remediation agent will drop) ---
POSTGRES_DB=tickets
POSTGRES_USER=lab
POSTGRES_PASSWORD=change-me-locally

# --- Lab run ID (used as a prefix for x-cai-metadata-session-id per agent) ---
# Leave blank to auto-generate at startup.
LAB_RUN_ID=
